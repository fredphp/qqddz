# 斗地主项目 .gitignore

# 依赖
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 测试
/coverage

# 构建输出
.next/
out/
build/
dist/

# 上传文件
upload/

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log

# 环境配置
.env
.env*
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db
*.pem

# Cocos Creator 编译缓存
library/
temp/
local/
local-*

# Go 编译产物
*.exe
*.exe~
*.dll
*.so
*.dylib

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Skills directory
/skills/
.claude
.z-ai-config
test
prompt
