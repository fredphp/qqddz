out/
build/
dist/

# 上传文件
upload/

# 日志
*.log
dev.log
dev.out.log
server.log

# 环境配置
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# Cocos Creator 编译缓存
library/
temp/
local/

# Go 编译产物
*.exe
*.exe~
*.dll
*.so
*.dylib
